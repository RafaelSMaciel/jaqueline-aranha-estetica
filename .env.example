# ═══════════════════════════════════════
# Shiva Zen — Variaveis de Ambiente
# Copie para .env e preencha os valores
# ═══════════════════════════════════════

# --- Django ---
DJANGO_SECRET_KEY=gere-uma-chave-secreta-unica-aqui
DEBUG=False
ALLOWED_HOSTS=seu-dominio.com.br,www.seu-dominio.com.br

# --- Banco de Dados (PostgreSQL) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=shivazen_prod
DB_USER=shivazen_user
DB_PASSWORD=sua-senha-segura
DB_HOST=localhost
DB_PORT=5432

# --- Redis (Cache e Sessoes) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- HTTPS (ativar em producao) ---
USE_HTTPS=True
CSRF_TRUSTED_ORIGINS=https://seu-dominio.com.br,https://www.seu-dominio.com.br

# --- Email (recuperacao de senha) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seuemail@gmail.com
EMAIL_HOST_PASSWORD=sua-app-password
DEFAULT_FROM_EMAIL=noreply@shivazen.com.br

# --- Sentry (monitoramento de erros, opcional) ---
# SENTRY_DSN=https://xxxx@sentry.io/yyyy
# SENTRY_TRACES_SAMPLE_RATE=0.2

# --- WhatsApp API (quando implementar) ---
# WHATSAPP_TOKEN=seu-token-meta
# WHATSAPP_VERIFY_TOKEN=seu-token-verificacao
# WHATSAPP_PHONE_ID=seu-phone-id
